# Backend Server Port (Render sets PORT automatically)
PORT=5001

# Production: frontend URL for CORS (e.g. https://your-app.onrender.com)
# FRONTEND_URL=https://your-frontend-url.com
# CORS_ORIGIN=https://your-frontend-url.com
